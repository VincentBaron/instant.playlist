# API configuration
NODE_ENV='development'
PORT=3030
CORS_ORIGIN='*'
FRONTEND_BASE_URL='http://localhost:3005'
BASE_URL='http://localhost:3030'
LOG_LEVEL='debug'

# Database
PGHOST='localhost'
PGUSER='postgres'
PGPASSWORD='postgres'
PGDATABASE='boilerplate'
PGPORT='5434'
PGMIN='15'
PGMAX='90'
PG_PUBLIC_URL='postgresql://localhost:5434/boilerplate'

# Grafana
METRICS_USERNAME='metrics'
METRICS_PASSWORD='secure_password'
LOKI_HOST='http://localhost:3102'

# Better Auth
BETTER_AUTH_SECRET='your-secret-key-at-least-32-characters-long'

# Google OAuth (optional — leave empty to disable)
# GOOGLE_CLIENT_ID=''
# GOOGLE_CLIENT_SECRET=''
