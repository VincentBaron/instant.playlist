{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "lib": ["ES2015"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@services/*": ["services/*"]
    }
  },
  "exclude": ["node_modules", "tests", "src/**/__tests__", "src/routes_tests"],
  "include": ["src"]
}
