# Server-side only — never expose to the client.

ANTHROPIC_API_KEY=          # vision: poster → artist names
SOUNDCLOUD_CLIENT_ID=       # SoundCloud API
SOUNDCLOUD_OAUTH_TOKEN=     # "2-..." or "OAuth 2-..."
DATABASE_URL=               # Postgres. Local: postgres://postgres:postgres@localhost:5434/instant_playlist (docker compose up -d). Prod: Fly Managed Postgres.
SET_MIN_DURATION_MIN=20     # optional; "set vs single" threshold

# Auth (better-auth) — required for uploads (the 3-free-scans quota lives on the account).
BETTER_AUTH_SECRET=         # random 32+ char secret (openssl rand -base64 32)
BETTER_AUTH_URL=            # app origin, e.g. http://localhost:3001
GOOGLE_CLIENT_ID=           # optional; enables Google one-tap (email OTP works without it)
GOOGLE_CLIENT_SECRET=       # optional; pairs with GOOGLE_CLIENT_ID
FREE_CREDITS=3              # optional; free scans granted once per account (default 3)

# Credits / paywall (Buy Me a Coffee)
NEXT_PUBLIC_BMC_URL=            # your public buymeacoffee.com/<slug> page (paywall link)
NEXT_PUBLIC_PRICE_PER_SCAN_CENTS=50  # optional; flat price of 1 scan in cents (default 50 = €0.50)
BMC_WEBHOOK_SECRET=            # BMC webhook secret; verifies the HMAC on /api/bmc/webhook
